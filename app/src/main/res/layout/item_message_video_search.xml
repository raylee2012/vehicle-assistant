<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="start"
    android:paddingStart="@dimen/spacing_small"
    android:paddingEnd="@dimen/bubble_side_margin"
    android:paddingTop="@dimen/bubble_gap"
    android:paddingBottom="@dimen/bubble_gap">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxWidth="@dimen/bubble_max_width"
        android:orientation="vertical"
        android:background="@drawable/bg_assistant_bubble"
        android:padding="12dp">

        <TextView
            android:id="@+id/tv_video_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎬 搜索："
            android:textColor="@color/bubble_ai_text"
            android:textSize="@dimen/body_medium"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_video_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="点击跳转抖音查看搜索结果"
            android:textColor="@color/hint_text"
            android:textSize="@dimen/body_small" />

        <Button
            android:id="@+id/btn_open_video"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="打开抖音 →"
            android:textSize="14sp"
            android:textColor="@android:color/white"
            android:background="@drawable/bg_button_pill"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:stateListAnimator="@null" />

    </LinearLayout>
</LinearLayout>
